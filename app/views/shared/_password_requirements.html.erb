<%# Live password-requirement checklist. Render inside an element with
    data-controller="password-strength"; the controller toggles `is-met` on
    each [data-rule] item and on the match line as the user types. %>
<ul class="pt-pw-reqs" aria-label="Password requirements">
  <% User::PASSWORD_REQUIREMENTS.each do |req| %>
    <li class="pt-pw-req" data-password-strength-target="rule" data-rule="<%= req[:key] %>">
      <span class="pt-pw-req-mark" aria-hidden="true"></span>
      <span><%= req[:label] %></span>
    </li>
  <% end %>
</ul>
<p class="pt-pw-match" data-password-strength-target="match" role="status" hidden></p>
