<% content_for :title, "Budget Planner" %>
<main class="pt-page">
  <section class="pt-hero">
    <div class="container-xl">
      <div class="pt-hero-grid">
        <div>
          <div class="pt-eyebrow">Budget planner</div>
          <h1 class="pt-h1">Shop smarter, spend less</h1>
          <p class="pt-lede">
            Set a spending limit and instantly see which products on your
            watchlist are within reach — priced at the lowest we've ever
            recorded for each one.
          </p>
        </div>
        <aside class="pt-hero-cta">
          <%= form_with url: budget_planner_path, method: :get, local: true do |f| %>
            <div class="pt-budget-card" style="background: var(--bg); border: 1px solid var(--line); border-radius: 16px; padding: 22px; box-shadow: 0 8px 22px -16px rgba(15,23,42,0.25); display:flex; flex-direction:column; gap:14px;">
              <% if @folders.any? %>
                <div>
                  <label for="folder_id" style="font-size: 12px; font-weight: 600; color: var(--ink); letter-spacing: 0.06em; text-transform: uppercase; display:block; margin-bottom:6px;">
                    Folder
                  </label>
                  <%= f.select :folder_id,
                        options_for_select(
                          [ [ "All products", "" ] ] + @folders.map { |folder| [ folder.name, folder.id ] },
                          @selected_folder&.id
                        ),
                        {},
                        style: "width:100%; padding:10px 12px; border:1px solid var(--border); border-radius:8px; font-size:0.95rem; background:var(--bg);" %>
                </div>
              <% end %>
              <% if @categories.present? %>
                <div>
                  <label for="category" style="font-size: 12px; font-weight: 600; color: var(--ink); letter-spacing: 0.06em; text-transform: uppercase; display:block; margin-bottom:6px;">
                    Category
                  </label>
                  <%= f.select :category,
                        options_for_select(
                          [ [ "All categories", "" ] ] + @categories.map { |c| [ c, c ] },
                          @selected_category
                        ),
                        {},
                        style: "width:100%; padding:10px 12px; border:1px solid var(--border); border-radius:8px; font-size:0.95rem; background:var(--bg);" %>
                </div>
              <% end %>
              <label for="budget" style="font-size: 12px; font-weight: 600; color: var(--ink); letter-spacing: 0.06em; text-transform: uppercase;">
                Your spending limit
              </label>
              <div style="display:flex; align-items:stretch; gap:0; border: 2px solid var(--ink); border-radius: 12px; overflow: hidden;">
                <span aria-hidden="true" style="display:grid; place-items:center; padding: 0 16px; background: var(--ink); color: #fff; font-size: 22px; font-weight: 700; font-family: var(--mono);">$</span>
                <%= f.number_field :budget,
                      value: @budget,
                      min: 0,
                      step: 0.01,
                      placeholder: "150.00",
                      required: true,
                      autofocus: @budget.blank?,
                      id: "budget",
                      style: "flex:1; min-width:0; border:none; padding: 14px 16px; font-size: 22px; font-weight: 600; font-family: var(--mono); background: var(--bg); outline: none; width: 100%;" %>
              </div>
              <div class="pt-field-hint" style="margin-top:-4px;">Enter the most you want to spend, then we'll show what fits.</div>
              <%= f.submit "See what fits", class: "pt-btn pt-btn-primary pt-btn-block pt-btn-lg" %>
            </div>
          <% end %>
        </aside>
      </div>
    </div>
  </section>

  <section class="container-xl pt-content">

    <% if @budget.nil? %>
      <div class="pt-empty">
        <div class="pt-empty-graphic">
          <svg viewBox="0 0 220 130" width="220" height="130">
            <rect x="20" y="10" width="180" height="110" rx="6" fill="none" stroke="var(--ink)" stroke-opacity="0.15" stroke-dasharray="4 4"/>
            <text x="110" y="80" text-anchor="middle" font-size="48" fill="var(--accent)" opacity="0.4">$</text>
          </svg>
        </div>
        <h2>Set a spending limit to get started</h2>
        <p>We'll match it against the lowest price we've recorded for each product on your watchlist.</p>
      </div>

    <% elsif @affordable.empty? && @over_budget.empty? %>
      <div class="pt-empty">
        <div class="pt-empty-icon"><%= render "shared/icon", name: "package", size: 32 %></div>
        <h3>No price data yet.</h3>
        <p>Start tracking products and logging prices — then come back to see what fits your budget.</p>
        <%= link_to "+ Add a product", new_product_path, class: "pt-btn pt-btn-primary" %>
      </div>

    <% else %>

      <%# Budget summary bar %>
      <div class="pt-budget-summary">
        <% if @selected_folder %>
          <%= render "summary_stat", label: "Folder", size: :sm,
                value: link_to(@selected_folder.name, @selected_folder, class: "pt-budget-stat-link") %>
        <% end %>
        <% if @selected_category %>
          <%= render "summary_stat", label: "Category", size: :sm, value: @selected_category %>
        <% end %>
        <%= render "summary_stat", label: "Spending limit",
              value: "$#{sprintf("%.2f", @budget)}" %>
        <%= render "summary_stat", label: "Cost to buy all in-range items", tone: :green,
              value: "$#{sprintf("%.2f", @total_if_all)}" %>
        <%= render "summary_stat", label: "Remaining", tone: (@remaining >= 0 ? :green : :orange),
              value: (@remaining >= 0 ? "+$#{sprintf("%.2f", @remaining)}" : "-$#{sprintf("%.2f", @remaining.abs)}") %>
        <%= render "summary_stat", label: "Products in range",
              value: "#{@affordable.size} of #{@affordable.size + @over_budget.size}" %>
      </div>

      <%# Spend by category (category-based budgeting) %>
      <% if @category_breakdown.present? && @category_breakdown.size > 1 %>
        <section class="pt-panel" style="margin-bottom:32px;padding:20px 24px;">
          <h2 style="font-size:1.1rem;font-weight:600;margin:0 0 16px;">
            Spend by category
            <span style="font-size:0.9rem;font-weight:400;color:var(--muted-2);margin-left:6px;">where your in-range picks would go</span>
          </h2>
          <% @category_breakdown.each do |row| %>
            <% pct = @total_if_all.positive? ? (row[:total] / @total_if_all * 100) : 0 %>
            <div style="margin-bottom:14px;">
              <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:5px;gap:12px;">
                <span style="font-weight:600;"><%= row[:category] %></span>
                <span style="font-size:13px;color:var(--muted-2);white-space:nowrap;">
                  <%= row[:count] %> <%= "item".pluralize(row[:count]) %> ·
                  <span class="pt-mono" style="color:var(--ink);font-weight:600;">$<%= sprintf("%.2f", row[:total]) %></span>
                </span>
              </div>
              <div style="height:8px;background:var(--bg-2);border-radius:99px;overflow:hidden;">
                <div style="height:100%;width:<%= pct.round(1) %>%;background:var(--accent);border-radius:99px;"></div>
              </div>
            </div>
          <% end %>
        </section>
      <% end %>

      <%# AI deal picks %>
      <% if @deal_picks.present? %>
        <section class="pt-panel pt-deal-picks" style="margin-bottom:32px;">
          <div class="pt-panel-head" style="padding:18px 22px 0;">
            <div>
              <div class="pt-panel-eyebrow">▌ <%= @deal_picks.first.source == "ai" ? "AI DEAL CURATOR" : "TOP DEAL PICKS" %></div>
              <h2 class="pt-panel-title">Worth grabbing right now</h2>
            </div>
            <span class="pt-source pt-source-<%= @deal_picks.first.source == "ai" ? "auto" : "manual" %>" title="<%= @deal_picks.first.source == "ai" ? "Generated by AI" : (LlmClient.enabled? ? "AI providers didn't respond — showing a heuristic pick instead" : "AI isn't enabled — showing a heuristic pick. Set GEMINI_API_KEY or OPENROUTER_API_KEY to turn it on.") %>">
              <%= @deal_picks.first.source == "ai" ? "AI" : "local" %>
            </span>
          </div>
          <% if @deal_picks.first.source != "ai" %>
            <p style="margin: 4px 22px -4px; font-size: 12px; color: var(--muted);">
              <% if LlmClient.enabled? %>
                The AI providers (Gemini + OpenRouter) didn't respond — these picks come from a local heuristic. Reload in a minute to try the AI again.
              <% else %>
                AI deal curation isn't enabled — these picks come from a local heuristic. Set <code>GEMINI_API_KEY</code> or <code>OPENROUTER_API_KEY</code> to turn it on.
              <% end %>
            </p>
          <% end %>
          <ol class="pt-deal-picks-list" style="list-style:none;margin:14px 0 0;padding:0 22px 22px;">
            <% @deal_picks.each_with_index do |pick, i| %>
              <li style="display:flex;gap:16px;padding:14px 0;border-top:1px solid var(--line-2);">
                <span class="pt-mono" style="color:var(--muted);font-size:13px;min-width:24px;">#<%= i + 1 %></span>
                <div style="flex:1;min-width:0;">
                  <%= link_to pick.product.name, pick.product, class: "pt-strong", style: "text-decoration:none;color:inherit;" %>
                  <div class="pt-muted" style="font-size:13px;margin-top:2px;"><%= pick.reason %></div>
                </div>
                <div style="text-align:right;">
                  <div class="pt-mono pt-strong" style="color:var(--accent-700);">$<%= sprintf("%.2f", pick.product.lowest_price_seen.to_f) %></div>
                  <div class="pt-muted small">lowest seen</div>
                </div>
              </li>
            <% end %>
          </ol>
        </section>
      <% end %>

      <%# Affordable items %>
      <% if @affordable.any? %>
        <h2 style="font-size:1.1rem;font-weight:600;margin-bottom:16px;">
          Ready to buy
          <span style="font-size:0.9rem;font-weight:400;color:var(--muted-2);margin-left:6px;"><%= @affordable.size %> <%= "product".pluralize(@affordable.size) %> at or under your limit</span>
        </h2>
        <div class="pt-grid" style="margin-bottom:40px;">
          <% @affordable.each do |product| %>
            <%= render "product_card", product: product, budget: @budget, tone: :affordable %>
          <% end %>
        </div>
      <% end %>

      <%# Over budget items %>
      <% if @over_budget.any? %>
        <h2 style="font-size:1.1rem;font-weight:600;margin-bottom:16px;color:var(--muted-2);">
          Not quite there yet
          <span style="font-size:0.9rem;font-weight:400;margin-left:6px;"><%= @over_budget.size %> <%= "product".pluralize(@over_budget.size) %> above your limit</span>
        </h2>
        <div class="pt-grid">
          <% @over_budget.each do |product| %>
            <%= render "product_card", product: product, budget: @budget, tone: :over %>
          <% end %>
        </div>
      <% end %>

    <% end %>
  </section>
</main>
