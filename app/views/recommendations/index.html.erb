<main class="pt-page">
  <section class="pt-hero">
    <div class="container-xl">
      <div class="pt-hero-grid">
        <div>
          <div class="pt-eyebrow">Budget planner</div>
          <h1 class="pt-h1">Recommendations</h1>
          <p class="pt-lede">
            Enter your budget and we'll show you which tracked products you can
            afford based on their lowest recorded price.
          </p>
        </div>
        <aside class="pt-hero-cta">
          <%= form_with url: recommendations_path, method: :get, local: true do |f| %>
            <div style="display:flex;flex-direction:column;gap:12px;">
              <label class="pt-filter-label" for="budget">Your budget ($)</label>
              <%= f.number_field :budget,
                    value: @budget,
                    min: 0,
                    step: 0.01,
                    placeholder: "e.g. 50.00",
                    class: "pt-search-input",
                    style: "width:100%;",
                    id: "budget" %>
              <%= f.submit "Find deals", class: "pt-btn pt-btn-primary pt-btn-block" %>
            </div>
          <% end %>
        </aside>
      </div>
    </div>
  </section>

  <section class="container-xl pt-content">
    <% if @budget.nil? %>
      <div class="pt-empty">
        <div class="pt-empty-graphic">
          <svg viewBox="0 0 220 130" width="220" height="130">
            <rect x="20" y="10" width="180" height="110" rx="6" fill="none" stroke="var(--ink)" stroke-opacity="0.15" stroke-dasharray="4 4"/>
            <text x="110" y="78" text-anchor="middle" font-size="48" fill="var(--accent)" opacity="0.5">$</text>
          </svg>
        </div>
        <h2>Set your budget</h2>
        <p>Enter an amount above and we'll recommend products that fit your wallet.</p>
      </div>

    <% elsif @recommendations.empty? && @over_budget.empty? %>
      <div class="pt-empty">
        <div class="pt-empty-icon">📦</div>
        <h3>No products with price records yet.</h3>
        <p>Add products and log prices first, then come back for recommendations.</p>
        <%= link_to "+ Add a product", new_product_path, class: "pt-btn pt-btn-primary" %>
      </div>

    <% else %>
      <%# Within budget section %>
      <% if @recommendations.any? %>
        <div class="pt-result-row" style="margin-bottom:16px;">
          <h2 style="font-size:1.2rem;font-weight:600;margin:0;">
            Within your $<%= sprintf("%.2f", @budget) %> budget
            <span style="font-size:0.9rem;font-weight:400;color:var(--muted-2);margin-left:8px;">
              <%= @recommendations.size %> <%= "product".pluralize(@recommendations.size) %>
            </span>
          </h2>
        </div>

        <div class="pt-grid" style="margin-bottom:40px;">
          <% @recommendations.each do |product| %>
            <% lowest = product.lowest_price_seen.to_f %>
            <% savings = @budget - lowest %>
            <article class="pt-card" style="border: 2px solid var(--green); position:relative;">
              <span style="position:absolute;top:10px;right:10px;z-index:10;background:var(--green);color:#fff;font-size:11px;font-weight:700;padding:3px 8px;border-radius:20px;letter-spacing:0.04em;">
                IN BUDGET
              </span>
              <%= link_to product_path(product), class: "pt-card-media", style: "text-decoration:none;color:inherit;" do %>
                <% if product.image_url.present? %>
                  <%= image_tag product.image_url, alt: product.name %>
                <% else %>
                  <div style="width:100%;height:100%;display:grid;place-items:center;font-size:42px;color:var(--muted);">📦</div>
                <% end %>
                <div class="pt-card-media-shade"></div>
                <span class="pt-tag pt-tag-overlay"><%= product.category %></span>
              <% end %>
              <div class="pt-card-body">
                <h3 class="pt-card-title">
                  <%= link_to product.name, product, style: "text-decoration:none;color:inherit;" %>
                </h3>
                <div class="pt-card-price-row">
                  <div class="pt-card-price-block">
                    <div class="pt-card-price" style="color:var(--green);">
                      $<%= sprintf("%.2f", lowest) %>
                    </div>
                    <div class="pt-card-store pt-muted">lowest price seen</div>
                  </div>
                </div>
                <div class="pt-card-low">
                  <span class="pt-card-low-dot" style="background:var(--green);"></span>
                  <span class="pt-card-low-label">Budget remaining</span>
                  <span class="pt-card-low-num" style="color:var(--green);">$<%= sprintf("%.2f", savings) %></span>
                </div>
              </div>
              <div class="pt-card-foot">
                <%= link_to "View details →", product, class: "pt-link-btn pt-link-btn-strong" %>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="pt-empty-filter" style="margin-bottom:40px;">
          <div class="pt-empty-icon">😔</div>
          <h3>No tracked products fit your $<%= sprintf("%.2f", @budget) %> budget.</h3>
          <p>Try raising your budget, or log lower prices if you've spotted a deal.</p>
        </div>
      <% end %>

      <%# Over budget section — helpful context %>
      <% if @over_budget.any? %>
        <div class="pt-result-row" style="margin-bottom:16px;">
          <h2 style="font-size:1.2rem;font-weight:600;margin:0;color:var(--muted-2);">
            Over budget
            <span style="font-size:0.9rem;font-weight:400;margin-left:8px;">
              <%= @over_budget.size %> <%= "product".pluralize(@over_budget.size) %> — cheapest first
            </span>
          </h2>
        </div>
        <div class="pt-grid">
          <% @over_budget.each do |product| %>
            <% lowest = product.lowest_price_seen.to_f %>
            <% shortfall = lowest - @budget %>
            <article class="pt-card" style="opacity:0.7;">
              <%= link_to product_path(product), class: "pt-card-media", style: "text-decoration:none;color:inherit;" do %>
                <% if product.image_url.present? %>
                  <%= image_tag product.image_url, alt: product.name %>
                <% else %>
                  <div style="width:100%;height:100%;display:grid;place-items:center;font-size:42px;color:var(--muted);">📦</div>
                <% end %>
                <div class="pt-card-media-shade"></div>
                <span class="pt-tag pt-tag-overlay"><%= product.category %></span>
              <% end %>
              <div class="pt-card-body">
                <h3 class="pt-card-title">
                  <%= link_to product.name, product, style: "text-decoration:none;color:inherit;" %>
                </h3>
                <div class="pt-card-price-row">
                  <div class="pt-card-price-block">
                    <div class="pt-card-price" style="color:var(--orange);">
                      $<%= sprintf("%.2f", lowest) %>
                    </div>
                    <div class="pt-card-store pt-muted">lowest price seen</div>
                  </div>
                </div>
                <div class="pt-card-low">
                  <span class="pt-card-low-dot" style="background:var(--orange);"></span>
                  <span class="pt-card-low-label">Over budget by</span>
                  <span class="pt-card-low-num" style="color:var(--orange);">$<%= sprintf("%.2f", shortfall) %></span>
                </div>
              </div>
              <div class="pt-card-foot">
                <%= link_to "View details →", product, class: "pt-link-btn pt-link-btn-strong" %>
              </div>
            </article>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </section>
</main>
