<% content_for :title, "Account settings" %>
<main class="pt-page">
  <section class="pt-hero pt-hero--compact">
    <div class="container-xl">
      <div class="pt-account-hero">
        <div class="pt-account-hero-avatar">
          <%= user_avatar_tag(@user, size: :large) %>
        </div>
        <div>
          <div class="pt-eyebrow">Account</div>
          <h1 class="pt-h1">Settings</h1>
          <p class="pt-lede"><%= @user.email_address %></p>
        </div>
      </div>
    </div>
  </section>

  <section class="container-xl pt-content">
    <div class="pt-account-settings">
      <section class="pt-settings-card">
        <header class="pt-settings-card-head">
          <h2 class="pt-settings-card-title">Profile photo</h2>
          <p class="pt-settings-card-desc">Shown in the header and on your account page.</p>
        </header>

        <div class="pt-avatar-upload">
          <%= form_with model: @user, url: account_path, method: :patch, local: true, html: { multipart: true }, class: "pt-form pt-avatar-upload-form" do |f| %>
            <div class="pt-field">
              <label class="pt-field-label" for="user_avatar">Upload image</label>
              <div class="pt-file-wrap">
                <%= f.file_field :avatar, accept: "image/png,image/jpeg,image/webp,image/gif", class: "pt-input pt-input-file" %>
              </div>
              <div class="pt-field-hint">PNG, JPEG, WebP, or GIF — max 5 MB.</div>
            </div>
            <div class="pt-form-actions-row">
              <%= f.submit "Save photo", class: "pt-btn pt-btn-primary" %>
              <% if @user.avatar.attached? %>
                <%= button_to "Remove photo",
                      account_path,
                      method: :patch,
                      params: { remove_avatar: "1" },
                      class: "pt-btn pt-btn-secondary",
                      data: { turbo_confirm: "Remove your profile photo?" } %>
              <% end %>
            </div>
          <% end %>
        </div>
      </section>

      <section class="pt-settings-card">
        <header class="pt-settings-card-head">
          <h2 class="pt-settings-card-title">Password</h2>
          <p class="pt-settings-card-desc">Keep your account secure with a strong password.</p>
        </header>

        <% if @user.oauth_user? %>
          <div class="pt-settings-note">
            You sign in with <strong>Google</strong>. Password changes are handled by your Google account.
          </div>
        <% else %>
          <%= form_with url: account_path, method: :patch, local: true, class: "pt-form" do %>
            <div class="pt-field">
              <label class="pt-field-label" for="current_password">Current password</label>
              <%= password_field_tag :current_password, nil, required: true, autocomplete: "current-password", class: "pt-input", maxlength: 72 %>
            </div>
            <div data-controller="password-strength" data-password-strength-min-length-value="<%= User::PASSWORD_MIN_LENGTH %>">
              <div class="pt-field">
                <label class="pt-field-label" for="password">New password</label>
                <%= password_field_tag :password, nil, required: true, autocomplete: "new-password", class: "pt-input", maxlength: 72,
                      data: { password_strength_target: "password", action: "input->password-strength#check" } %>
                <%= render "shared/password_requirements" %>
              </div>
              <div class="pt-field">
                <label class="pt-field-label" for="password_confirmation">Confirm new password</label>
                <%= password_field_tag :password_confirmation, nil, required: true, autocomplete: "new-password", class: "pt-input", maxlength: 72,
                      data: { password_strength_target: "confirmation", action: "input->password-strength#checkMatch" } %>
              </div>
            </div>
            <%= submit_tag "Update password", class: "pt-btn pt-btn-primary" %>
          <% end %>
        <% end %>
      </section>

      <section class="pt-settings-card pt-settings-card--danger">
        <header class="pt-settings-card-head">
          <h2 class="pt-settings-card-title">Delete account</h2>
          <p class="pt-settings-card-desc">
            Permanently delete your account, products, price records, and folders. This cannot be undone.
          </p>
        </header>

        <%= form_with url: account_path, method: :delete, local: true, class: "pt-form",
              data: { turbo_confirm: "Delete your account and all data permanently?" } do %>
          <% if @user.oauth_user? %>
            <div class="pt-field">
              <label class="pt-field-label" for="email_confirmation">Type your email to confirm</label>
              <%= email_field_tag :email_confirmation, nil, required: true, class: "pt-input", placeholder: @user.email_address, autocomplete: "off" %>
            </div>
          <% else %>
            <div class="pt-field">
              <label class="pt-field-label" for="password_confirmation">Current password</label>
              <%= password_field_tag :password_confirmation, nil, required: true, autocomplete: "current-password", class: "pt-input", maxlength: 72 %>
            </div>
          <% end %>
          <%= submit_tag "Delete my account", class: "pt-btn pt-btn-danger" %>
        <% end %>
      </section>
    </div>
  </section>
</main>
