<% content_for :title, @folder.name %>
<main class="pt-page">
  <section class="pt-hero">
    <div class="container-xl">
      <div class="pt-hero-grid">
        <div>
          <div class="pt-eyebrow"><%= link_to "Folders", folders_path, class: "pt-inline-link" %></div>
          <h1 class="pt-h1"><%= @folder.name %></h1>
          <% if @folder.description.present? %>
            <p class="pt-hero-note"><%= @folder.description %></p>
          <% end %>
        </div>
        <aside class="pt-hero-cta">
          <div class="pt-hero-meta">
            <span class="pt-hero-meta-dot"></span>
            <span><strong><%= @pagy.count %></strong> <%= "product".pluralize(@pagy.count) %></span>
          </div>
          <div class="pt-folder-actions">
            <%= link_to edit_folder_path(@folder), class: "pt-btn pt-btn-ghost pt-btn-sm" do %>
              <%= render "shared/icon", name: "edit", size: 14 %> Edit folder
            <% end %>
            <%= link_to @folder, data: { turbo_method: :delete, turbo_confirm: "Delete \"#{@folder.name}\"? Products won't be deleted." }, class: "pt-btn pt-btn-danger-ghost pt-btn-sm" do %>
              <%= render "shared/icon", name: "trash", size: 14 %> Delete
            <% end %>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <%= form_with url: folder_path(@folder), method: :get, local: true, data: { controller: "auto-submit", turbo_frame: "_top" } do |f| %>
    <section class="pt-toolbar-wrap">
      <div class="container-xl">
        <div class="pt-toolbar">
          <div class="pt-search">
            <span class="pt-search-icon"><%= render "shared/icon", name: "search", size: 16 %></span>
            <%= f.text_field :search,
                  value: params[:search],
                  placeholder: "Search by name, category, description…",
                  class: "pt-search-input",
                  data: { action: "input->auto-submit#queue" } %>
            <% if params[:search].present? %>
              <%= link_to "×", folder_path(@folder, params.permit(:category, :tag, :sort).to_h), class: "pt-search-clear", "aria-label": "Clear search" %>
            <% end %>
          </div>

          <div class="pt-filter-group">
            <label class="pt-filter-label" for="category">Category</label>
            <%= f.select :category,
                  options_for_select([ [ "All", "" ] ] + @categories, params[:category]),
                  {}, class: "pt-select", data: { action: "change->auto-submit#submitNow" } %>
          </div>

          <div class="pt-filter-group">
            <label class="pt-filter-label" for="tag">Tag</label>
            <%= f.select :tag,
                  options_for_select([ [ "All", "" ] ] + @tags.map { |tag| [ tag, tag ] }, params[:tag]),
                  {}, class: "pt-select", data: { action: "change->auto-submit#submitNow" } %>
          </div>

          <div class="pt-filter-group">
            <label class="pt-filter-label" for="sort">Sort</label>
            <%= f.select :sort,
                  options_for_select(
                    [
                      [ "Newest first",        "newest" ],
                      [ "Oldest first",        "oldest" ],
                      [ "Name · A→Z",          "name_asc" ],
                      [ "Name · Z→A",          "name_desc" ],
                      [ "Price · low → high",  "price_asc" ],
                      [ "Price · high → low",  "price_desc" ]
                    ],
                    params[:sort].presence || "newest"
                  ),
                  {}, class: "pt-select", data: { action: "change->auto-submit#submitNow" } %>
          </div>

          <% if params[:search].present? || params[:category].present? || params[:tag].present? || (params[:sort].present? && params[:sort] != "newest") %>
            <%= link_to "Clear filters", folder_path(@folder), class: "pt-link-btn pt-link-btn-strong" %>
          <% end %>

          <%= f.submit "Apply", style: "display:none;", tabindex: -1, "aria-hidden": "true" %>
        </div>

        <% if @products_not_in_folder.any? %>
          <div class="pt-folder-add-bar">
            <%= form_with url: folder_folder_products_path(@folder), method: :post, class: "pt-folder-add-form" do |af| %>
              <%= af.select :product_id,
                    @products_not_in_folder.map { |p| [ p.name, p.id ] },
                    { prompt: "Add a product to this folder…" },
                    class: "pt-input pt-folder-add-select" %>
              <%= af.submit "Add", class: "pt-btn pt-btn-primary pt-btn-sm" %>
            <% end %>
          </div>
        <% end %>

        <div class="pt-result-row">
          <span class="pt-result-count">
            <% if @pagy && @pagy.count > @products_in_folder.size %>
              Showing <%= @pagy.from %>–<%= @pagy.to %> of <%= @pagy.count %>
              <%= "product".pluralize(@pagy.count) %>
            <% else %>
              <%= @products_in_folder.size %> <%= "product".pluralize(@products_in_folder.size) %> in this folder
            <% end %>
          </span>
        </div>
      </div>
    </section>
  <% end %>

  <section class="container-xl pt-content">
    <% if @products_in_folder.any? %>
      <div class="pt-grid">
        <% @products_in_folder.each do |product| %>
          <% latest = product.latest_price %>
          <article class="pt-card">
            <%= link_to product_path(product), class: "pt-card-media", style: "text-decoration: none; color: inherit;" do %>
              <% if product.image_url.present? %>
                <%= image_tag product.image_url, alt: product.name %>
              <% else %>
                <div class="pt-img-fallback"><%= render "shared/icon", name: "package", size: 48 %></div>
              <% end %>
              <div class="pt-card-media-shade"></div>
              <span class="pt-tag pt-tag-overlay"><%= product.category %></span>
            <% end %>
            <div class="pt-card-body">
              <h3 class="pt-card-title">
                <%= link_to product.name, product, style: "text-decoration: none; color: inherit;" %>
              </h3>
              <% if product.tags.any? %>
                <div class="pt-tag-list">
                  <% product.tags.each do |tag| %>
                    <%= link_to tag, folder_path(@folder, tag: tag), class: "pt-mini-tag" %>
                  <% end %>
                </div>
              <% end %>
              <div class="pt-card-price-row">
                <div class="pt-card-price">
                  <% if latest %>$<%= sprintf("%.2f", latest) %><% else %>—<% end %>
                </div>
              </div>
            </div>
            <div class="pt-card-foot">
              <%= link_to "View details →", product, class: "pt-link-btn pt-link-btn-strong", aria: { label: "View details for #{product.name}" } %>
              <%= button_to "× Remove",
                    folder_folder_product_path(@folder, product),
                    method: :delete,
                    class: "pt-btn pt-btn-danger-ghost pt-btn-sm",
                    aria: { label: "Remove #{product.name} from folder" } %>
            </div>
          </article>
        <% end %>
      </div>

      <% if @pagy && @pagy.pages > 1 %>
        <div class="pt-pagination">
          <%== pagy_nav(@pagy) %>
        </div>
      <% end %>
    <% else %>
      <div class="pt-empty">
        <div class="pt-empty-icon"><%= render "shared/icon", name: "folder", size: 48 %></div>
        <% if params[:search].present? || params[:category].present? || params[:tag].present? %>
          <p class="pt-empty-text">No products match your filters.</p>
          <%= link_to "Clear filters", folder_path(@folder), class: "pt-btn pt-btn-ghost" %>
        <% else %>
          <p class="pt-empty-text">This folder is empty.</p>
          <% if @products_not_in_folder.any? %>
            <p class="pt-muted">Use the dropdown above to add products.</p>
          <% else %>
            <%= link_to "Add a product", new_product_path, class: "pt-btn pt-btn-primary" %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </section>
</main>
