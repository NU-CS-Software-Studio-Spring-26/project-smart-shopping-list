<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for?(:title) ? "#{content_for(:title)} · PriceTracker" : "PriceTracker" %></title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="manifest" href="/manifest.webmanifest">
    <meta name="theme-color" content="#1d1d1f">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="PriceTracker">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <a href="#main-content" class="pt-skip-link">Skip to main content</a>
    <header class="pt-header" data-controller="nav" data-action="keydown@window->nav#closeOnEscape">
      <div class="pt-header-inner container-xl">
        <%= link_to root_path, class: "pt-brand" do %>
          <span class="pt-brand-mark">P/T</span>
          <span class="pt-brand-name">PriceTracker</span>
        <% end %>

        <button type="button"
                class="pt-nav-toggle"
                data-nav-target="button"
                data-action="click->nav#toggle"
                aria-controls="pt-primary-nav"
                aria-expanded="false"
                aria-label="Toggle navigation menu">
          <span class="pt-nav-toggle-bar"></span>
          <span class="pt-nav-toggle-bar"></span>
          <span class="pt-nav-toggle-bar"></span>
        </button>

        <nav id="pt-primary-nav" class="pt-nav" data-nav-target="menu" data-action="click->nav#close">
          <% if authenticated? %>
            <%= link_to "Products", products_path, class: "pt-nav-link #{'is-active' if controller_name == 'products'}" %>
            <%= link_to "Price Records", price_records_path, class: "pt-nav-link #{'is-active' if controller_name == 'price_records'}" %>
            <%= link_to "Reports", reports_path, class: "pt-nav-link #{'is-active' if controller_name == 'reports'}" %>
            <%= link_to "Budget Planner", budget_planner_path, class: "pt-nav-link #{'is-active' if controller_name == 'budget_planner'}" %>
            <%= link_to "Ask AI", assistant_path, class: "pt-nav-link #{'is-active' if controller_name == 'assistant'}" %>
          <% end %>
          <%= link_to "Supported Sites", supported_retailers_path, class: "pt-nav-link #{'is-active' if controller_name == 'pages' && action_name == 'supported_retailers'}" %>
        </nav>

        <div class="pt-header-right">
          <% if authenticated? %>
            <div class="pt-header-account">
              <%= link_to account_path,
                    class: "pt-account-chip #{'is-active' if controller_name == 'accounts'}",
                    aria: { current: (controller_name == 'accounts' ? "page" : nil) } do %>
                <%= user_avatar_tag(Current.user) %>
                <span class="pt-account-chip-label">
                  <span class="pt-account-chip-name">
                    <%= Current.user.name.presence || Current.user.email_address.split("@").first %>
                  </span>
                  <span class="pt-account-chip-meta">Account</span>
                </span>
              <% end %>
              <%= button_to "Sign out",
                    session_path,
                    method: :delete,
                    class: "pt-btn pt-btn-ghost pt-btn-sm",
                    form: { class: "pt-header-signout-form" } %>
            </div>
          <% else %>
            <%= link_to "Sign in", new_session_path, class: "pt-btn pt-btn-ghost" %>
            <%= link_to "Create account", new_registration_path, class: "pt-btn pt-btn-primary" %>
          <% end %>
        </div>
      </div>
    </header>

    <%= render "shared/flash" %>

    <div id="main-content" tabindex="-1"></div>
    <%= yield %>

    <%# Global Ask AI launcher. Skipped on the assistant page itself so the
        ask_ai_results Turbo Frame id stays unique in the response. %>
    <% if authenticated? && controller_name != "assistant" %>
      <%= render "shared/ask_ai_widget" %>
    <% end %>

    <footer class="pt-footer">
      <div class="container-xl pt-footer-inner">
        <div class="pt-footer-brand">
          <span class="pt-brand-mark">P/T</span>
          <div>
            <div class="pt-footer-title">PriceTracker</div>
            <div class="pt-footer-sub">Track every price change across stores.</div>
          </div>
        </div>
        <div class="pt-footer-cols">
          <div>
            <div class="pt-footer-h">Product</div>
            <% if authenticated? %>
              <%= link_to "Products", products_path %>
              <%= link_to "Price Records", price_records_path %>
              <%= link_to "Reports", reports_path %>
              <%= link_to "Budget Planner", budget_planner_path %>
              <%= link_to "Ask AI", assistant_path %>
            <% end %>
            <%= link_to "Supported Sites", supported_retailers_path %>
            <% if authenticated? %><%= link_to "+ Add a product", new_product_path %><% end %>
          </div>
          <div>
            <div class="pt-footer-h">Account</div>
            <% if authenticated? %>
              <%= button_to "Sign out", session_path, method: :delete, form: { style: "display:inline" } %>
            <% else %>
              <%= link_to "Sign in", new_session_path %>
              <%= link_to "Create account", new_registration_path %>
            <% end %>
          </div>
          <div>
            <div class="pt-footer-h">About</div>
            <%= link_to "About us", about_path %>
            <a href="https://github.com/NU-CS-Software-Studio-Spring-26/project-smart-shopping-list" target="_blank" rel="noopener noreferrer">GitHub</a>
          </div>
          <div>
            <div class="pt-footer-h">Legal</div>
            <%= link_to "Privacy", privacy_path %>
            <%= link_to "Terms & Disclaimer", terms_path %>
          </div>
        </div>
      </div>
      <div class="pt-footer-rule">
        <div class="container-xl pt-footer-bottom">
          <span>© <%= Date.current.year %> PriceTracker</span>
          <span class="pt-mono">v 1.0 · ledger build</span>
        </div>
      </div>
    </footer>
  </body>
</html>
