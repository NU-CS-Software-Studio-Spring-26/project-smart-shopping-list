<%# Answer / empty / example-question states. Rendered both on the standalone
    /ask page and (via the ask_ai_results Turbo Frame) inside the floating
    Ask AI widget on every page. Reads @answer, @query, @products,
    @example_questions set by AssistantController#index. %>
<% if @answer && @answer.source != "empty" %>
  <section class="pt-panel" style="margin-top: 28px;">
    <div class="pt-panel-head" style="padding: 18px 22px 0;">
      <div>
        <div class="pt-panel-eyebrow">▌ <%= @answer.source == "ai" ? "AI ANSWER" : "TOP MATCHES" %></div>
        <h2 class="pt-panel-title">Suggestions for "<%= @query.truncate(80) %>"</h2>
      </div>
      <span class="pt-source pt-source-<%= @answer.source == "ai" ? "auto" : "manual" %>"
            title="<%= @answer.source == "ai" ? "Generated by AI" : (LlmClient.enabled? ? "AI providers didn't respond — showing a heuristic keyword match instead" : "AI isn't enabled — showing a heuristic keyword match. Set GEMINI_API_KEY or OPENROUTER_API_KEY to turn it on.") %>">
        <%= @answer.source == "ai" ? "AI" : "local" %>
      </span>
    </div>

    <% if @answer.source != "ai" %>
      <div role="status" style="margin: 12px 22px 0; padding: 10px 14px; background: #fff7e6; border: 1px solid #f5d99a; border-radius: 8px; color: #6b4a00; font-size: 13px; line-height: 1.4;">
        <% if LlmClient.enabled? %>
          <strong>AI providers didn't respond.</strong>
          We tried Gemini first, then OpenRouter's free-model cascade — both rate-limited or timed out. These results come from a local keyword match. Reload in a minute to retry the AI.
        <% else %>
          <strong>AI suggestions aren't enabled.</strong>
          These results come from a local keyword match. Set <code>GEMINI_API_KEY</code> or <code>OPENROUTER_API_KEY</code> to turn on AI answers.
        <% end %>
      </div>
    <% end %>

    <% if @answer.summary.present? %>
      <p style="padding: 12px 22px 0; color: var(--ink-2);"><%= @answer.summary %></p>
    <% end %>

    <% if @answer.picks.any? %>
      <ol style="list-style:none;margin:14px 0 0;padding:0 22px 22px;">
        <% @answer.picks.each_with_index do |pick, i| %>
          <li style="display:flex;gap:16px;padding:14px 0;border-top:1px solid var(--line-2);">
            <span class="pt-mono" style="color:var(--muted);font-size:13px;min-width:24px;">#<%= i + 1 %></span>
            <div style="flex:1;min-width:0;">
              <%= link_to pick.product.name, pick.product, class: "pt-strong", style: "text-decoration:none;color:inherit;", data: { turbo_frame: "_top" } %>
              <div class="pt-muted" style="font-size:13px;margin-top:2px;"><%= pick.reason %></div>
            </div>
            <div style="text-align:right;">
              <% latest = pick.product.latest_price %>
              <% if latest %>
                <div class="pt-mono pt-strong">$<%= sprintf("%.2f", latest) %></div>
                <div class="pt-muted small">latest</div>
              <% end %>
            </div>
          </li>
        <% end %>
      </ol>
    <% else %>
      <p style="padding: 12px 22px 22px; color: var(--muted);">
        No matching products on your watchlist. Try a different question or add more products first.
      </p>
    <% end %>
  </section>
<% elsif @query.present? && @products.empty? %>
  <div class="pt-empty" style="margin-top: 24px;">
    <h2>Your watchlist is empty</h2>
    <p>The assistant works against your tracked products. Add a product to get started.</p>
    <%= link_to "+ Add a product", new_product_path, class: "pt-btn pt-btn-primary", data: { turbo_frame: "_top" } %>
  </div>
<% elsif @example_questions.any? %>
  <section style="margin-top: 24px;">
    <div class="pt-eyebrow" style="margin-bottom: 12px;">Try one of these</div>
    <div style="display: flex; flex-wrap: wrap; gap: 8px;">
      <% @example_questions.each do |q| %>
        <%= link_to q, assistant_path(q: q), class: "pt-btn pt-btn-secondary", style: "border-radius: 980px; font-weight: 400;", data: { turbo_frame: "_top" } %>
      <% end %>
    </div>
  </section>
<% end %>
