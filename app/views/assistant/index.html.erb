<% content_for :title, "Ask AI" %>
<main class="pt-page">
  <section class="pt-hero">
    <div class="container-xl">
      <div class="pt-eyebrow">AI Assistant</div>
      <h1 class="pt-h1">Ask anything about your watchlist</h1>
      <p class="pt-lede">
        Type a question in plain English. The assistant looks at the products you're tracking, their current and historical prices, and your target prices, then suggests up to <%= AiAssistant::MAX_PICKS %> picks with reasoning.
      </p>
    </div>
  </section>

  <section class="container-xl pt-content">
    <%= form_with url: assistant_path, method: :get, local: true, class: "pt-assistant-form", data: { controller: "loading-button", action: "submit->loading-button#busy" } do |f| %>
      <div class="pt-field">
        <label class="pt-field-label" for="q">Your question</label>
        <%= f.text_field :q,
              value: @query,
              placeholder: "e.g. anything good under $200 right now?",
              class: "pt-input pt-input-block",
              autofocus: true,
              autocomplete: "off",
              maxlength: 240 %>
      </div>
      <div class="pt-form-actions" style="margin-top: 12px;">
        <%= f.submit "Ask",
              class: "pt-btn pt-btn-primary pt-btn-lg",
              data: { loading_button_target: "submit", busy_label: "Thinking…" } %>
        <% if @query.present? %>
          <%= link_to "Clear", assistant_path, class: "pt-link-btn" %>
        <% end %>
      </div>
    <% end %>

    <%= turbo_frame_tag "ask_ai_results" do %>
      <%= render "results" %>
    <% end %>
  </section>
</main>
